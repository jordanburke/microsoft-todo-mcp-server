{
  "name": "microsoft-todo-mcp-server",
  "version": "1.1.3",
  "description": "Microsoft Todo MCP service for Claude and Cursor. Fork of @jhirono/todomcp",
  "main": "dist/todo-index.js",
  "dependencies": {
    "@azure/msal-node": "^3.8.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "zod": "^3.25.76"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "build": "ts-builds build",
    "build:watch": "ts-builds build:watch",
    "dev": "ts-builds build && node dist/cli.js",
    "start": "node dist/todo-index.js",
    "cli": "node dist/cli.js",
    "auth": "node dist/auth-server.js",
    "setup": "node dist/setup.js",
    "create-config": "node dist/create-mcp-config.js",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "prepublishOnly": "pnpm validate",
    "postinstall": "echo 'Run: npx microsoft-todo-mcp-server setup' to configure"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/microsoft-todo-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "cursor",
    "claude",
    "microsoft-todo",
    "todo"
  ],
  "author": "Jordan Burke <jordan.burke@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jordanburke/microsoft-todo-mcp-server/issues"
  },
  "homepage": "https://github.com/jordanburke/microsoft-todo-mcp-server#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.21",
    "ts-builds": "^3.2.0",
    "tsdown": "^0.22.2"
  },
  "type": "module",
  "bin": {
    "microsoft-todo-mcp-server": "./dist/cli.js",
    "mstodo": "./dist/cli.js",
    "mstodo-config": "./dist/create-mcp-config.js",
    "mstodo-setup": "./dist/setup.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
